{
  "dashboard": {
    "title": "LeadGen - Workers Dashboard",
    "description": "Celery workers and queue monitoring",
    "tags": ["leadgen", "workers", "celery"],
    "timezone": "utc",
    "panels": [
      {
        "title": "Queue Sizes",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "queue_size{queue_name=\"high_priority\"}",
            "legendFormat": "High Priority"
          },
          {
            "expr": "queue_size{queue_name=\"default\"}",
            "legendFormat": "Default"
          },
          {
            "expr": "queue_size{queue_name=\"scraping\"}",
            "legendFormat": "Scraping"
          },
          {
            "expr": "queue_size{queue_name=\"email\"}",
            "legendFormat": "Email"
          },
          {
            "expr": "queue_size{queue_name=\"low_priority\"}",
            "legendFormat": "Low Priority"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {"lineWidth": 2}
          }
        }
      },
      {
        "title": "Active Workers",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "celery_workers_active",
            "legendFormat": "Active Workers"
          }
        ]
      },
      {
        "title": "Tasks Processed per Second",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(celery_tasks_total[$__rate_interval])",
            "legendFormat": "Tasks/sec"
          }
        ]
      },
      {
        "title": "Task Success Rate",
        "type": "stat",
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "(sum(celery_tasks_total{status=\"success\"}) / sum(celery_tasks_total)) * 100",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "title": "Failed Tasks by Type",
        "type": "barchart",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by (task_name) (rate(celery_tasks_total{status=\"failed\"}[$__rate_interval]))",
            "legendFormat": "{{task_name}}"
          }
        ]
      },
      {
        "title": "Task Duration (95th Percentile)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket[$__rate_interval])) by (le, task_name))",
            "legendFormat": "{{task_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      }
    ],
    "refresh": "30s",
    "time": {"from": "now-1h", "to": "now"}
  }
}